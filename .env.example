# ── Database (Vercel Postgres) ────────────────────────────────────────────────
# Created automatically when you add Vercel Postgres from the dashboard.
# Run: npx vercel env pull .env.local  to get these locally.
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NO_SSL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# ── QuickBooks (Accounting + Payments) ────────────────────────────────────────
# Single OAuth app covers both QB Accounting and QB Payments.
# Required OAuth scopes:
#   com.intuit.quickbooks.accounting
#   com.intuit.quickbooks.payment
#
# 1. Create app at https://developer.intuit.com
# 2. Add both scopes above
# 3. OAuth flow → get refresh token (long-lived, stored securely)
# 4. Set NEXT_PUBLIC_QB_PAYMENTS_APP_KEY (from app settings → Keys)
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REALM_ID=
QB_REFRESH_TOKEN=
QB_PAYMENTS_BASE_URL=https://api.intuit.com/quickbooks/v4/payments
QB_WEBHOOK_VERIFIER_TOKEN=

# QB Payments — client-side tokenization key (safe to expose, public)
# Used by qbpayments.js to tokenize card numbers in the browser
NEXT_PUBLIC_QB_PAYMENTS_APP_KEY=

# ── AI (Anthropic Claude) — OPTIONAL ─────────────────────────────────────────
# Only needed if you want:
#   - AI eligibility pre-screening at intake
#   - AI clinical summaries for providers
#   - Patient chat assistant
# Leave blank to disable all AI features.
ANTHROPIC_API_KEY=sk-ant-

# ── Webhook Secrets ───────────────────────────────────────────────────────────
LIFEFILE_WEBHOOK_SECRET=
PRACTICEQ_WEBHOOK_KEY=
SPRUCE_WEBHOOK_SECRET=

# ── Service Mode ──────────────────────────────────────────────────────────────
# Set to "true" to switch from mock to real for each service
USE_REAL_INTEGRATIONS=false
USE_REAL_PRACTICEQ=false
PRACTICEQ_API_KEY=
PRACTICEQ_BASE_URL=https://api.practiceq.com/v2

USE_REAL_LIFEFILE=false
LIFEFILE_VENDOR_ID=
LIFEFILE_LOCATION_ID=
LIFEFILE_API_NETWORK_ID=
LIFEFILE_API_USERNAME=
LIFEFILE_API_PASSWORD=
LIFEFILE_PRACTICE_ID=
LIFEFILE_BASE_URL=https://host100-7.lifefile.net/lfapi/v1

# Pharmacy provider: lifefile or appsheet.
# AppSheet mock mode builds and stores the exact rows without writing to AppSheet.
PHARMACY_PROVIDER=lifefile
USE_REAL_APPSHEET=false
APPSHEET_ID=
APPSHEET_API_KEY=
APPSHEET_BASE_URL=https://www.appsheet.com
APPSHEET_ORDER_TABLE=OrderItems
APPSHEET_PHARMACY_ORDER_TABLE=PharmacyOrder
APPSHEET_CLIENT_TABLE=Client

USE_REAL_SPRUCE=false
SPRUCE_API_KEY=
SPRUCE_FROM_NUMBER=
SPRUCE_BASE_URL=https://api.sprucehealth.com/v1

# ── E2E Tests ─────────────────────────────────────────────────────────────────
E2E_BASE_URL=http://localhost:3000
