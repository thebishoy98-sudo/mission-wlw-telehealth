# ─────────────────────────────────────────────────────────────────────────────
# Mission WLW — Environment Variables
# Copy to .env.local for local development.
# In Vercel: set via Dashboard → Project Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (HIPAA § 164.312(e) — Transmission Security) ─────────────────────
# Vercel Postgres auto-sets POSTGRES_URL when you connect a database.
# Vercel Postgres uses Neon (AES-256 at rest, TLS 1.2+ in transit).
# You MUST sign a BAA with Vercel before storing PHI in production.
# https://vercel.com/docs/storage/vercel-postgres/hipaa
POSTGRES_URL=

# ── QuickBooks Payments (PCI DSS — never log card numbers) ────────────────────
# OAuth 2.0 credentials from Intuit Developer Portal → Your App → Keys & OAuth
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REFRESH_TOKEN=      # Long-lived refresh token from OAuth flow
QB_REALM_ID=           # Company ID from QB → Settings → Account and Settings
QB_ENVIRONMENT=sandbox # "sandbox" or "production"
# Client-side tokenization key (exposed to browser — safe to make public)
NEXT_PUBLIC_QB_PAYMENTS_APP_KEY=

# ── QuickBooks Webhook ─────────────────────────────────────────────────────────
# Intuit Developer Portal → Your App → Webhooks → Verifier Token
QB_WEBHOOK_VERIFIER_TOKEN=

# ── PracticeQ ─────────────────────────────────────────────────────────────────
PRACTICEQ_API_KEY=
PRACTICEQ_WEBHOOK_SECRET=  # For validating incoming webhooks from PracticeQ

# ── Life File Pharmacy ────────────────────────────────────────────────────────
LIFEFILE_API_KEY=
LIFEFILE_WEBHOOK_SECRET=   # HMAC secret for validating Life File webhook payloads

# ── FedEx Tracking ────────────────────────────────────────────────────────────
# FedEx Developer Portal OAuth credentials for direct package status polling.
FEDEX_CLIENT_ID=
FEDEX_CLIENT_SECRET=
FEDEX_API_BASE_URL=https://apis.fedex.com

# ── Spruce Health (SMS) ───────────────────────────────────────────────────────
SPRUCE_API_KEY=
SPRUCE_WEBHOOK_SECRET=     # HMAC secret for validating Spruce webhook payloads

# ── Anthropic AI (HIPAA: BAA required before using with real PHI) ─────────────
# Sign BAA at console.anthropic.com → Organization → HIPAA
# Until BAA is signed, use only de-identified data with AI routes.
ANTHROPIC_API_KEY=

# ── Security (HIPAA § 164.312(a) — Access Control) ───────────────────────────
# Secret shared by admin dashboard pages. Set to a strong random string.
# Generate: openssl rand -hex 32
ADMIN_SECRET=

# ── Application ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
