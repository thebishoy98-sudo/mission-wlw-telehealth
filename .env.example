# ── Database (Vercel Postgres) ────────────────────────────────────────────────
# Created automatically when you add Vercel Postgres from the dashboard.
# Run: npx vercel env pull .env.local  to get these locally.
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NO_SSL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# ── Stripe Payments ───────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_
STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# ── AI (Anthropic Claude) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-

# ── Webhook Secrets ───────────────────────────────────────────────────────────
LIFEFILE_WEBHOOK_SECRET=
PRACTICEQ_WEBHOOK_KEY=
SPRUCE_WEBHOOK_SECRET=

# ── Service Mode ─────────────────────────────────────────────────────────────
# Set to "true" to enable all real integrations at once, or enable individually
USE_REAL_INTEGRATIONS=false

# ── PracticeQ ──────────────────────────────────────────────────────────────────
USE_REAL_PRACTICEQ=false
PRACTICEQ_API_KEY=
PRACTICEQ_BASE_URL=https://api.practiceq.com/v2

# ── QuickBooks Online ─────────────────────────────────────────────────────────
USE_REAL_QUICKBOOKS=false
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REALM_ID=
QB_REFRESH_TOKEN=

# ── Life File Pharmacy ────────────────────────────────────────────────────────
USE_REAL_LIFEFILE=false
LIFEFILE_VENDOR_ID=
LIFEFILE_LOCATION_ID=
LIFEFILE_API_NETWORK_ID=
LIFEFILE_API_KEY=
LIFEFILE_BASE_URL=https://api.lifefilehealth.com/v1

# ── Spruce SMS ────────────────────────────────────────────────────────────────
USE_REAL_SPRUCE=false
SPRUCE_API_KEY=
SPRUCE_FROM_NUMBER=
SPRUCE_BASE_URL=https://api.sprucehealth.com/v1

# ── E2E Tests ─────────────────────────────────────────────────────────────────
# Override base URL for E2E tests (default: http://localhost:3000)
E2E_BASE_URL=http://localhost:3000
